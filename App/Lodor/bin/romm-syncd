#!/bin/sh
# romm-syncd - periodic, charging-gated, Wi-Fi-dark save sync for muOS.  MARKER: LODOR_SYNCD
#
# A tiny POSIX-sh loop (NOT a resident Go process - it must hold ~nothing and only spawn the
# short-lived engine per cycle). Launched DETACHED from MUOS/init/ so it never delays boot.
# Polls every POLL s, acts at most every INTERVAL s, and only when ALL gates hold: charging,
# not in a game, credentials present. It pushes the offline pending-saves queue; it never
# pulls (pulls happen around launch, where the core context is known).
set -u
SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "$SELF_DIR/../lib/romm-sync-lib.sh"
lodor_export_env

POLL=60
INTERVAL="${ROMM_SYNC_INTERVAL:-1800}"   # act at most every 30 min
last_attempt=$(date +%s)

# Drop the transfer mutex on any exit (owner-scoped: no-op unless this cycle holds it).
trap 'wifi_release' EXIT INT TERM HUP QUIT

# prefetch_work - OFFLINE census (engine --prefetch-discs --dry: manifest walk + file
# stats, no config/host/network): are there downloaded multi-disc games with missing
# discs (lodor#7 disc-1-first leaves later discs as 0-byte stubs)? Gates the radio the
# same way the pending queue does — an empty census means no wakeup. Knob:
# LODOR_PREFETCH_DISCS=off disables (default on, this lane's env-knob pattern).
prefetch_work() {
	[ "${LODOR_PREFETCH_DISCS:-on}" != "off" ] || return 1
	( cd "$DATA_DIR" 2>/dev/null || log "WARN cd $DATA_DIR (prefetch census)"; "$BIN" --prefetch-discs --dry 2>/dev/null ) | grep -q 'discs_missing=[1-9]'
}

log "romm-syncd started (interval=${INTERVAL}s, poll=${POLL}s)"

while :; do
	sleep "$POLL"
	now=$(date +%s)
	[ $((now - last_attempt)) -ge "$INTERVAL" ] || continue
	is_charging   || continue
	not_in_game   || continue
	creds_present || continue
	# Anything to do? Skip the radio entirely if the queue is empty AND no multi-disc
	# game is waiting on discs (both checks are offline file reads).
	if [ ! -s "$PENDING" ] && ! prefetch_work; then last_attempt=$(date +%s); continue; fi

	# Transfer mutex FIRST (bg: the daemon never preempts a user action). BUSY must NOT
	# consume the timer — a sync IS happening, just not ours; retry next poll.
	wifi_acquire bg; acq=$?
	if [ "$acq" = 2 ]; then
		log "transfer mutex busy (another actor); retry next poll"
		continue
	fi
	last_attempt=$(date +%s)
	if wifi_bring_up; then
		set_clock_bounded
		lodor_ensure_device
		out="$("$BIN" --push-pending 2>&1)"; rc=$?
		printf '%s\n' "$out" >> "$LOG"
		wifi_lock_refresh   # long cycle: keep the held lock's ts fresh between engine calls
		# Handoff v1: also drain the offline pending-STATES queue (savestates). The launch
		# hooks queue states on-exit; only this daemon drains them offline. Best-effort — a
		# stuck state must never wedge the save flush above.
		"$BIN" --push-pending-states >> "$LOG" 2>&1 || true
		# Multi-disc prefetch (lodor#7 hybrid): after the pending queues drain, quietly
		# complete any downloaded multi-disc game still missing discs on the SAME warm
		# link (launches fetch disc-1-first; this makes mid-game disc swaps work without
		# a relaunch). Best-effort, quietly logged; failures re-surface next census.
		if [ "${LODOR_PREFETCH_DISCS:-on}" != "off" ]; then
			wifi_lock_refresh
			# Re-check the in-game gate NOW: the queue drain above can run long, and a
			# game may have started since the poll-top check — a heavy prefetch must
			# never compete with a running game.
			if not_in_game; then
				( cd "$DATA_DIR" 2>/dev/null || log "WARN cd $DATA_DIR (prefetch)"; "$BIN" --prefetch-discs ) >> "$LOG" 2>&1 \
					|| log "prefetch-discs failed (retry next interval)"
			else
				log "prefetch skipped: game started during the cycle"
			fi
		fi
		log "push-pending + push-pending-states rc=$rc"
	else
		log "wifi unavailable; retry next interval"
	fi
	wifi_release
done
